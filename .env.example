# CalmSkin environment template — copy to `.env` and fill in real values.
# `.env` is git-ignored; never commit real secrets.

# --- Postgres ---
POSTGRES_USER=calm_skin
POSTGRES_PASSWORD=change-me
POSTGRES_DB_USER_SERVICE=calmskin_user
POSTGRES_DB_PRODUCT_SERVICE=calmskin_product
POSTGRES_DB_INVENTORY_SERVICE=calmskin_inventory
POSTGRES_DB_ORDER_SERVICE=calmskin_order
POSTGRES_DB_PAYMENT_SERVICE=calmskin_payment
POSTGRES_DB_NOTIFICATION_SERVICE=calmskin_notification
POSTGRES_DB_PROMOTION_SERVICE=calmskin_promotion
POSTGRES_DB_REVIEW_SERVICE=calmskin_review
POSTGRES_DB_SHIPPING_SERVICE=calmskin_shipping
POSTGRES_DB_SUBSCRIPTION_SERVICE=calmskin_subscription
POSTGRES_DB_CHATBOT=calmskin_chatbot
POSTGRES_DB_AI_SKIN_ANALYSIS=calmskin_ai_skin_analysis

# --- Security (generate strong random values) ---
JWT_SECRET=change-me-long-random-string
INTERNAL_SECRET=change-me-long-random-string
SHIPPING_WEBHOOK_SECRET=change-me-random

# --- AI / external (live keys required for AI services) ---
GEMINI_API_KEY=your-gemini-api-key
CLOUDINARY_URL=cloudinary://key:secret@cloud

# --- Mail (notification-service) ---
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your-smtp-user
MAIL_PASSWORD=your-smtp-password
MAIL_FROM=no-reply@calmskin.local

# --- Web push (notification-service) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@calmskin.local

# --- Misc ---
PUBLIC_BASE_URL=http://localhost:8080
